generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(uuid())
  name     String
  role     String
  email    String @unique
  password String
}

model Material {
  id              String      @id @default(uuid())
  materialId      String      @unique // e.g., MAT-101
  heatNumber      String
  supplier        String
  grade           String
  qrCode          String?
  certificateFile String?
  createdAt       DateTime    @default(now())
  components      Component[]
}

model Component {
  id              String           @id @default(uuid())
  componentId     String           @unique // e.g., CMP-101
  type            String // e.g., Body, Seat
  materialId      String
  material        Material         @relation(fields: [materialId], references: [id])
  qrCode          String
  machine         String?
  createdAt       DateTime         @default(now())
  valveComponents ValveComponent[]
}

model Valve {
  id             String           @id @default(uuid())
  valveId        String           @unique // e.g., VLV-2026-001
  serialNumber   String           @unique
  qrCode         String?
  assemblyStatus String           @default("Pending") // Pending, Assembled, Tested, Packed, Dispatched
  createdAt      DateTime         @default(now())
  components     ValveComponent[]
  testReports    TestReport[]
  logs           ProcessLog[]
}

model ValveComponent {
  id          String    @id @default(uuid())
  valveId     String
  valve       Valve     @relation(fields: [valveId], references: [id])
  componentId String
  component   Component @relation(fields: [componentId], references: [id])
}

model ProcessLog {
  id           String   @id @default(uuid())
  entityId     String // Valve ID or Component ID
  entityType   String // Valve, Component, Material
  processStage String // Machining, Assembly, etc.
  machine      String?
  operator     String
  timestamp    DateTime @default(now())
  status       String
  valve        Valve?   @relation(fields: [entityId], references: [id])
}

model TestReport {
  id           String   @id @default(uuid())
  valveId      String
  valve        Valve    @relation(fields: [valveId], references: [id])
  pressureTest String
  leakTest     String
  result       String
  reportFile   String?
  createdAt    DateTime @default(now())
}
